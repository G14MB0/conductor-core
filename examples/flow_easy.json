{
  "name": "example",
  "start": [
    "branch"
  ],
  "nodes": [
    {
      "id": "branch",
      "name": "Branch",
      "executor": "inline",
      "callable": "examples.flow_functions:branching",
      "timeout": 5.0,
      "env": {
        "KEY": "VALUE"
      },
      "transitions": {
        "even": [
          "process"
        ],
        "odd": [
          "process"
        ]
      }
    },
    {
      "id": "process",
      "executor": "process",
      "callable": "examples.flow_functions:intensive",
      "timeout": 5.0,
      "env": {
        "KEY": "VALUE"
      }
    }
  ]
}